# Requires:
#   sudo a2enmod proxy proxy_http headers

<VirtualHost *:80>
    ServerName example.com

    ProxyRequests Off
    ProxyPreserveHost On

    # Forward the original request scheme so ASP.NET Core can detect https correctly.
    RequestHeader set X-Forwarded-Proto expr=%{REQUEST_SCHEME}

    ProxyPass / http://127.0.0.1:5000/ timeout=60
    ProxyPassReverse / http://127.0.0.1:5000/

    ErrorLog ${APACHE_LOG_DIR}/portfolio-site-error.log
    CustomLog ${APACHE_LOG_DIR}/portfolio-site-access.log combined
</VirtualHost>
