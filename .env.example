# =========================================
# Portfolio Site .env example
# このファイルは記入例です。
# 実運用では値を自分の環境に合わせて変更してください。
# =========================================

# -----------------------------------------
# HTTP Server
# 0.0.0.0: 外部からアクセス可能
# 127.0.0.1: ローカル専用
# -----------------------------------------
PORTFOLIO_HOST=0.0.0.0
PORTFOLIO_PORT=8000

# -----------------------------------------
# Admin Authentication
# 本番では PORTFOLIO_ADMIN_PASSWORD を使わず、
# PORTFOLIO_ADMIN_PASSWORD_HASH を設定してください。
# ハッシュ生成:
# python3 scripts/generate_admin_password_hash.py
# -----------------------------------------
PORTFOLIO_ADMIN_ID=admin
PORTFOLIO_ADMIN_PASSWORD=
PORTFOLIO_ADMIN_PASSWORD_HASH=scrypt$16384$8$1$REPLACE_WITH_YOUR_SALT$REPLACE_WITH_YOUR_HASH

# HTTPS 配下なら true
PORTFOLIO_COOKIE_SECURE=true

# -----------------------------------------
# MySQL Connection
# Ubuntu Server 上の MySQL へ接続する想定例
# -----------------------------------------
PORTFOLIO_DB_HOST=192.168.10.20
PORTFOLIO_DB_PORT=3306
PORTFOLIO_DB_NAME=portfolio_site
PORTFOLIO_DB_USER=portfolio_app
PORTFOLIO_DB_PASSWORD=change-this-password
PORTFOLIO_DB_CHARSET=utf8mb4
PORTFOLIO_DB_TABLE=portfolio_documents

# 接続タイムアウト秒
PORTFOLIO_DB_CONNECT_TIMEOUT=10

# 初回構築だけ true を検討
# 本番では false 推奨
PORTFOLIO_DB_AUTO_CREATE=false
