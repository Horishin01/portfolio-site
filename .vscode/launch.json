{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PortfolioSite",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "rebuild",
      "program": "${workspaceFolder}/bin/Debug/net8.0/PortfolioSite.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5078"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "windows": {
        "program": "C:/Users/Owner/Documents/GitHub/portfolio-site/bin/Debug/net8.0/PortfolioSite.dll",
        "cwd": "C:/Users/Owner/Documents/GitHub/portfolio-site"
      }
    }
  ]
}
