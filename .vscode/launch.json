        "ADMIN_LOGIN_ID": "admin",
        "ADMIN_PASSWORD_HASH": "AQAAAAIAAYagAAAAEFcEgy07tuTAsnHf5YxiA/ziZeBz2Q1rq1OraUIU6EckDA9XIERnYHPr4CqFNBnZ/g=="
      },
      "serverReadyAction": {
        "action": "openExternally",
