@{
    var pageTitle = ViewData["Title"] as string ?? "Portfolio Site";
    var metaDescription = ViewData["MetaDescription"] as string ?? "Portfolio Site";
    var defaultFaviconHref = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%230f766e'/%3E%3Ctext x='50%25' y='57%25' font-size='28' font-family='Arial,sans-serif' font-weight='700' text-anchor='middle' fill='white'%3EST%3C/text%3E%3C/svg%3E";
    var faviconHref = PublicUrlSanitizer.SanitizeFaviconUrlOrDefault(ViewData["FaviconHref"] as string, defaultFaviconHref);
    var adsenseEnabled = ViewData["AdsenseEnabled"] as bool? == true;
    var adsensePublisherId = GoogleAdsensePublisherId.Normalize(ViewData["AdsensePublisherId"] as string);
    var isAdminSignedIn = User.Identity?.IsAuthenticated == true && User.IsInRole(AdminRoles.Administrator);
    var adminSessionEvent = TempData["AdminSessionEvent"] as string ?? "";
}
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@metaDescription" />
    <title>@pageTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap"
    />
    <link
      rel="icon"
      href="@faviconHref"
    />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    @if (adsenseEnabled && !string.IsNullOrWhiteSpace(adsensePublisherId))
    {
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=@adsensePublisherId" crossorigin="anonymous"></script>
    }
  </head>
  <body data-admin-context="public" data-admin-session-event="@adminSessionEvent">
    @if (isAdminSignedIn)
    {
      <aside class="admin-session-bar" aria-label="管理者セッション">
        <div>
          <span>Admin</span>
          <strong>@(User.Identity?.Name ?? "管理者")</strong>
        </div>
        <nav aria-label="管理者メニュー">
          <a asp-controller="Admin" asp-action="Edit">編集へ戻る</a>
          <a asp-controller="Admin" asp-action="Index">ポータル</a>
          <form asp-controller="Admin" asp-action="Logout" method="post" data-admin-session-event-submit="logout">
            <button type="submit">ログアウト</button>
          </form>
        </nav>
      </aside>
    }
    @RenderBody()
    <script src="~/js/admin-session-sync.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
  </body>
</html>
