@model PortfolioDocument
@{
    ViewData["Title"] = Model.SiteTitle;
    ViewData["MetaDescription"] = Model.MetaDescription;

    static IEnumerable<string> SplitLines(string? value)
    {
        return (value ?? string.Empty)
            .Split('\n', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Select(item => item.TrimStart('-', '*', '+', ' '));
    }

    static IEnumerable<string> SplitParagraphs(string? value)
    {
        return (value ?? string.Empty)
            .Split("\n\n", StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Select(item => item.Replace("\n", " ").Trim());
    }

    static string GetInitials(string? value)
    {
        return string.Concat(
            (value ?? string.Empty)
                .Split(' ', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(item => item[0])
        ).ToUpperInvariant();
    }

    var shortName = string.IsNullOrWhiteSpace(Model.Profile.ShortName)
        ? GetInitials(Model.Profile.Name)
        : Model.Profile.ShortName;
    var footerRole = string.IsNullOrWhiteSpace(Model.FooterRole)
        ? Model.Profile.Role
        : Model.FooterRole;
    var heroImageSrc = PublicUrlSanitizer.SanitizeImageUrl(Model.Profile.HeroImageSrc);
    var hasHeroImage = !string.IsNullOrWhiteSpace(heroImageSrc);
    var safeContactLinks = Model.Contact.Links
        .Select(link => new
        {
            Link = link,
            Href = PublicUrlSanitizer.SanitizeLinkUrl(link.Href)
        })
        .Where(entry => !string.IsNullOrWhiteSpace(entry.Href))
        .ToList();
}
<div class="background-grid" aria-hidden="true"></div>
<div class="background-orb background-orb-left" aria-hidden="true"></div>
<div class="background-orb background-orb-right" aria-hidden="true"></div>

<div class="page-shell">
  <header class="site-header">
    <a class="brand" href="#top" aria-label="ページ上部へ移動">
      <span class="brand-mark">@shortName</span>
      <span class="brand-copy">
        <strong>@Model.Profile.Name</strong>
        <small>@Model.Profile.Role</small>
      </span>
    </a>

    <button
      class="site-nav-toggle"
      id="siteNavToggle"
      type="button"
      aria-expanded="false"
      aria-controls="siteNav"
      aria-label="メニューを開閉"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="siteNav" aria-label="グローバルナビゲーション">
      <a href="#profile">PROFILE</a>
      <a href="#career">CAREER</a>
      <a href="#skills">SKILL</a>
      <a href="#works">WORKS</a>
      <a href="#personal">PERSONAL</a>
      <a href="#contact">CONTACT</a>
    </nav>
  </header>

  <main id="top">
    <section class="hero section @(hasHeroImage ? "has-hero-image" : string.Empty)" id="heroSection">
      <div class="hero-copy reveal">
        <p class="eyebrow">@Model.Profile.HeroEyebrow</p>
        <h1>@Model.Profile.HeroTitle</h1>
        <p class="hero-summary">@Model.Profile.Summary</p>

        <ul class="hero-tag-list" aria-label="主な技術">
          @foreach (var tag in SplitLines(Model.Profile.Tags))
          {
              <li>@tag</li>
          }
        </ul>
      </div>

      <div class="hero-side">
        <figure class="hero-visual reveal @(hasHeroImage ? "has-image" : string.Empty)" aria-label="プロフィールイメージ">
          @if (hasHeroImage)
          {
              <img
                class="image-preview-media"
                src="@heroImageSrc"
                alt="@(string.IsNullOrWhiteSpace(Model.Profile.HeroImageAlt) ? $"{Model.Profile.Name} image" : Model.Profile.HeroImageAlt)"
                fetchpriority="high"
                decoding="async"
              />
          }
          else
          {
              <div class="hero-visual-placeholder" aria-hidden="true">
                <span class="hero-visual-mark">@shortName</span>
                <div class="hero-visual-copy">
                  <strong>Image / Illustration</strong>
                  <p>プロフィール写真やイラストを表示できます。</p>
                </div>
              </div>
          }
        </figure>

        <aside class="hero-panel reveal" aria-label="担当領域の概要">
          <p class="panel-kicker">Core Focus</p>
          <div class="hero-highlight-list">
            @foreach (var highlight in Model.Profile.Highlights)
            {
                <article>
                  <span>@highlight.Label</span>
                  <strong>@highlight.Value</strong>
                </article>
            }
          </div>
        </aside>
      </div>
    </section>

    <section class="section" id="profile">
      <div class="section-heading reveal">
        <p class="eyebrow">PROFILE</p>
        <h2>@Model.ProfileSection.Heading</h2>
        <p class="section-intro">@Model.ProfileSection.Intro</p>
      </div>

      <div class="profile-grid">
        <article class="panel reveal">
          <h3>Overview</h3>
          <p class="lead-copy">@Model.ProfileSection.Lead</p>
          <div class="body-copy">
            @foreach (var paragraph in SplitParagraphs(Model.ProfileSection.Body))
            {
                <p>@paragraph</p>
            }
          </div>
        </article>

        <article class="panel panel-stack reveal">
          <div>
            <h3>@Model.ProfileSection.FocusHeading</h3>
            <ul class="focus-list">
              @foreach (var item in SplitLines(Model.ProfileSection.FocusItems))
              {
                  <li>@item</li>
              }
            </ul>
          </div>

          <div>
            <h3>@Model.ProfileSection.CertificationsHeading</h3>
            <ul class="chip-list">
              @foreach (var item in SplitLines(Model.ProfileSection.Certifications))
              {
                  <li>@item</li>
              }
            </ul>
          </div>
        </article>
      </div>
    </section>

    <section class="section" id="career">
      <div class="section-heading reveal">
        <p class="eyebrow">CAREER</p>
        <h2>@Model.CareerSection.Heading</h2>
        <p class="section-intro">@Model.CareerSection.Intro</p>
      </div>

      <div class="timeline">
        @foreach (var entry in Model.CareerSection.Items)
        {
            <article class="timeline-item reveal">
              <div class="timeline-side">
                <span class="timeline-period">@entry.Period</span>
                @if (!string.IsNullOrWhiteSpace(entry.Category))
                {
                    <span class="timeline-kind">@entry.Category</span>
                }
              </div>
              <div class="timeline-content">
                <h4>@entry.Organization</h4>
                @if (!string.IsNullOrWhiteSpace(entry.Title))
                {
                    <p class="timeline-role">@entry.Title</p>
                }
                @if (!string.IsNullOrWhiteSpace(entry.Description))
                {
                    <p>@entry.Description</p>
                }
                @if (SplitLines(entry.Highlights).Any())
                {
                    <ul class="timeline-highlights">
                      @foreach (var item in SplitLines(entry.Highlights))
                      {
                          <li>@item</li>
                      }
                    </ul>
                }
              </div>
            </article>
        }
      </div>
    </section>

    <section class="section" id="skills">
      <div class="section-heading reveal">
        <p class="eyebrow">SKILL</p>
        <h2>@Model.SkillsSection.Heading</h2>
        <p class="section-intro">@Model.SkillsSection.Intro</p>
      </div>

      <div class="skills-stack">
        @foreach (var category in Model.SkillsSection.Categories)
        {
            <article class="skill-card reveal">
              <div class="skill-card-head">
                <h3>@category.Title</h3>
                <p>@category.Summary</p>
              </div>

              <div class="skill-table">
                <div class="skill-table-row skill-table-head">
                  <span>技術</span>
                  <span>経験</span>
                  <span>補足</span>
                </div>
                @foreach (var item in category.Items)
                {
                    <div class="skill-table-row">
                      <strong>@item.Name</strong>
                      <span class="skill-experience">@item.Experience</span>
                      <p>@item.Note</p>
                    </div>
                }
              </div>
            </article>
        }
      </div>
    </section>

    <section class="section" id="works">
      <div class="section-heading reveal">
        <p class="eyebrow">WORKS</p>
        <h2>@Model.WorksSection.Heading</h2>
        <p class="section-intro">@Model.WorksSection.Intro</p>
      </div>

      <div class="works-list">
        @foreach (var work in Model.WorksSection.Items)
        {
            <article class="work-card reveal">
              <div class="work-summary">
                <div class="work-meta">
                  <span>@work.Type</span>
                  <span>@work.Year</span>
                </div>
                <h3>@work.Title</h3>
                <p class="work-role">@work.Role</p>
                <p>@work.Summary</p>
              </div>

              <div class="work-detail">
                <section class="work-block">
                  <span class="work-block-title">担当内容</span>
                  <ul class="bullet-list">
                    @foreach (var item in SplitLines(work.Responsibilities))
                    {
                        <li>@item</li>
                    }
                  </ul>
                </section>

                <section class="work-block">
                  <span class="work-block-title">成果</span>
                  <ul class="bullet-list">
                    @foreach (var item in SplitLines(work.Outcomes))
                    {
                        <li>@item</li>
                    }
                  </ul>
                </section>

                <section class="work-block">
                  <span class="work-block-title">使用技術</span>
                  <ul class="stack-list">
                    @foreach (var item in SplitLines(work.Stack))
                    {
                        <li>@item</li>
                    }
                  </ul>
                </section>
              </div>
            </article>
        }
      </div>
    </section>

    <section class="section" id="personal">
      <div class="section-heading reveal">
        <p class="eyebrow">PERSONAL</p>
        <h2>@Model.PersonalSection.Heading</h2>
        <p class="section-intro">@Model.PersonalSection.Intro</p>
      </div>

      <div class="personal-grid">
        @for (var index = 0; index < Model.PersonalSection.Items.Count; index++)
        {
            var item = Model.PersonalSection.Items[index];
            var personalSlug = PersonalItemRouteHelper.CreateSlug(item.Title);
            var personalSummary = string.IsNullOrWhiteSpace(item.Summary) ? item.DetailSummary : item.Summary;
            var personalStack = SplitLines(item.Stack).Take(4).ToList();
            var personalImageSrc = PublicUrlSanitizer.SanitizeImageUrl(item.ImageSrc);
            var hasPersonalImage = !string.IsNullOrWhiteSpace(personalImageSrc);
            var personalImageAlt = string.IsNullOrWhiteSpace(item.ImageAlt) ? $"{item.Title} の写真" : item.ImageAlt;
            var personalTopicCount = SplitLines(item.Points).Count();
            <a
              class="personal-card personal-card-link reveal"
              asp-action="Personal"
              asp-controller="Home"
              asp-route-index="@index"
              asp-route-slug="@(!string.IsNullOrWhiteSpace(personalSlug) ? personalSlug : null)"
              aria-label="@($"{item.Title} の詳細を見る")"
            >
              @if (hasPersonalImage)
              {
                  <figure class="personal-card-media" aria-hidden="true">
                    <img src="@personalImageSrc" alt="@personalImageAlt" loading="lazy" decoding="async" />
                  </figure>
              }
              <div class="personal-card-copy">
                <div class="personal-scope-row">
                  <span class="personal-scope-badge">一覧カード</span>
                  <p class="personal-meta">@item.Category</p>
                </div>
                <h3>@item.Title</h3>
                <p class="personal-summary">@personalSummary</p>
                <p class="personal-summary-note">この一覧カードから個別ページへ移動します。</p>
              </div>
              <div class="personal-card-foot">
                <div class="personal-card-stats" aria-label="取り組みの概要">
                  <span>個別ページあり</span>
                  <span>@(personalTopicCount == 0 ? "詳細項目未設定" : $"{personalTopicCount}項目")</span>
                  @if (hasPersonalImage)
                  {
                      <span>画像あり</span>
                  }
                </div>
                @if (personalStack.Count > 0)
                {
                    <ul class="stack-list">
                      @foreach (var stackItem in personalStack)
                      {
                          <li>@stackItem</li>
                      }
                    </ul>
                }
                <span class="personal-cta">個別ページを見る</span>
              </div>
            </a>
        }
      </div>
    </section>

    <section class="section" id="contact">
      <div class="contact-panel reveal">
        <div>
          <p class="eyebrow">CONTACT</p>
          <h2>@Model.Contact.Heading</h2>
          <p class="contact-note">@Model.Contact.Note</p>
        </div>

        <div class="contact-actions">
          @if (!string.IsNullOrWhiteSpace(Model.Contact.Email))
          {
              <a class="button" href="mailto:@Model.Contact.Email">@Model.Contact.Email</a>
          }

          <div class="social-list">
            @foreach (var entry in safeContactLinks)
            {
                var isExternalLink = PublicUrlSanitizer.IsExternalHttpLink(entry.Href);
                <a
                  href="@entry.Href"
                  target="@(isExternalLink ? "_blank" : null)"
                  rel="@(isExternalLink ? "noreferrer" : null)"
                >@entry.Link.Label</a>
            }
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>
      <span>@Model.Profile.Name</span>
      <span>·</span>
      <span>@footerRole</span>
    </p>
  </footer>
</div>
