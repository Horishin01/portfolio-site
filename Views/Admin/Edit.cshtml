                  <p class="empty-message">個人活動項目はまだありません。必要な数だけ追加してください。</p>
              }
              @for (var i = 0; i < doc.PersonalSection.Items.Count; i++)
              {
                  var selectedPersonalStack = SplitSelectionValues(doc.PersonalSection.Items[i].Stack);
                  var personalStackGroups = BuildSelectionOptionGroups(
                      PortfolioEditorOptionCatalog.TechnologyOptionGroups,
                      doc.PersonalSection.Items[i].Stack,
                      PortfolioEditorOptionCatalog.KnownTechnologyOptions
                  );
                  var personalImagePreviewSrc = PublicUrlSanitizer.SanitizeImageUrl(doc.PersonalSection.Items[i].ImageSrc);
                  var hasPersonalImage = !string.IsNullOrWhiteSpace(personalImagePreviewSrc);
                  var personalImageFieldName = GetPersonalItemImageFieldName(i);
