                      <p class="field-help item-card-route">個別URL: /personal/@i@(string.IsNullOrWhiteSpace(personalSlug) ? string.Empty : $"/{personalSlug}")</p>
                      <div class="personal-item-jump" aria-label="この個人活動の編集先">
                        <a href="#personal-listing-@i">一覧カード</a>
                        <a href="#personal-detail-@i">個別ページ</a>
                        <a href="#personal-shared-@i">共通素材</a>
                      </div>
                    </div>
                    <div class="editor-scope-grid">
                      <section class="editor-scope-card is-listing" id="personal-listing-@i" aria-label="一覧カード設定" data-personal-tab-panel="listing">
                        <span class="editor-scope-label">一覧カード</span>
                        <h5>トップページの PERSONAL 一覧に出す内容</h5>
                        <div class="field-grid">
                          <div class="field">
                            <label asp-for="Document.PersonalSection.Items[i].Category"></label>
                            <p class="field-help">カード上部の分類です。例: 個人開発、学習記録、コミュニティ</p>
                            <input asp-for="Document.PersonalSection.Items[i].Category" data-character-count data-character-limit="24" />
                            <p class="field-help character-counter" aria-live="polite">0 / 24 文字目安</p>
                          </div>
                          <div class="field">
                            <label asp-for="Document.PersonalSection.Items[i].Title"></label>
                            <p class="field-help">一覧カードと個別ページのタイトルです。URL の識別にも使います。</p>
                            <input asp-for="Document.PersonalSection.Items[i].Title" data-character-count data-character-limit="60" />
                            <p class="field-help character-counter" aria-live="polite">0 / 60 文字目安</p>
