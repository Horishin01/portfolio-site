                            <p class="field-help character-counter" aria-live="polite">0 / 140 文字目安</p>
                          </div>
                        </div>
                      </section>

                      <section class="editor-scope-card is-detail" id="personal-detail-@i" aria-label="個別ページ設定" data-personal-tab-panel="detail">
                        <div class="editor-scope-heading">
                          <span class="editor-scope-label">個別ページ専用</span>
                          <a
                            class="editor-scope-link"
                            asp-controller="Home"
                            asp-action="Personal"
                            asp-route-index="@i"
                            asp-route-slug="@(!string.IsNullOrWhiteSpace(personalSlug) ? personalSlug : null)"
                            target="_blank"
                            rel="noreferrer"
                          >
                            表示確認
                          </a>
                        </div>
                        <h5>カードを開いた後の詳細ページに出す内容</h5>
                        <div class="field-grid is-single">
                          <div class="field field-full">
                            <label asp-for="Document.PersonalSection.Items[i].DetailSummary"></label>
                            <p class="field-help">個別ページ上部の導入文です。未入力の場合は一覧カードの概要を使います。</p>
                            <textarea asp-for="Document.PersonalSection.Items[i].DetailSummary" data-character-count data-character-limit="220"></textarea>
                            <p class="field-help character-counter" aria-live="polite">0 / 220 文字目安</p>
                          </div>
                          <div class="field field-full">
                            <label asp-for="Document.PersonalSection.Items[i].DetailBody"></label>
                            <p class="field-help">個別ページ本文です。空行で段落を分けると、そのまま段落として表示します。</p>
                            <textarea asp-for="Document.PersonalSection.Items[i].DetailBody" data-character-count data-character-limit="1200"></textarea>
                            <p class="field-help character-counter" aria-live="polite">0 / 1200 文字目安</p>
                          </div>
                          <div class="field field-full">
                            <label asp-for="Document.PersonalSection.Items[i].Points"></label>
                            <p class="field-help">個別ページの箇条書きに使います。1行につき1項目で入力してください。</p>
                            <textarea asp-for="Document.PersonalSection.Items[i].Points" data-character-count data-character-limit="500"></textarea>
                            <p class="field-help character-counter" aria-live="polite">0 / 500 文字目安</p>
                          </div>
                        </div>
                      </section>

                      <section class="editor-scope-card is-shared" id="personal-shared-@i" aria-label="共通素材" data-personal-tab-panel="shared">
                        <span class="editor-scope-label">共通素材</span>
                        <h5>一覧カードと個別ページの両方で使う内容</h5>
                        <div class="field-grid is-single">
                          <div class="field field-full image-field">
                            <label>活動写真</label>
                            <div class="image-field-shell">
                              <div class="personal-preview-row">
                                <div class="image-preview-card personal-preview-card @(hasPersonalImage ? "has-image" : string.Empty)" id="personalImagePreviewCard-@i">
                                  <img
                                    class="image-preview-media"
                                    id="personalImagePreviewMedia-@i"
                                    src="@(hasPersonalImage ? personalImagePreviewSrc : string.Empty)"
                                    alt="@(string.IsNullOrWhiteSpace(doc.PersonalSection.Items[i].ImageAlt) ? $"{doc.PersonalSection.Items[i].Title} の画像プレビュー" : doc.PersonalSection.Items[i].ImageAlt)"
                                    hidden="@(!hasPersonalImage)"
                                  />
                                  <div class="image-preview-placeholder">
                                    <span class="image-preview-mark">PIC</span>
                                    <div class="image-preview-copy">
                                      <strong>個人活動の写真</strong>
                                      <p>カードのサムネイルと詳細ページのメインビジュアルに使います。アップロードまたは URL 入力でここに反映されます。</p>
                                    </div>
                                  </div>
                                </div>

                                <div class="field hero-upload-field">
                                  <label for="personalImageFile-@i">写真アップロード</label>
                                  <input id="personalImageFile-@i" name="@personalImageFieldName" type="file" accept=".jpg,.jpeg,.png,.webp,.gif" />
                                  <p class="field-help">JPG / PNG / WEBP / GIF に対応しています。5MBまでアップロードでき、画像URLより優先して保存されます。</p>
                                  <p class="field-help">写真をアップロードしない場合は、下の画像URLを使用します。説明文は alt として保存されます。</p>
                                  <p class="field-help">画像URLは / で始まるサイト内パス、または https の URL のみ指定できます。</p>

                                  <div class="hero-upload-meta">
                                    <div class="field">
                                      <label asp-for="Document.PersonalSection.Items[i].ImageSrc"></label>
                                      <p class="field-help">一覧カードと個別ページで使う画像 URL です。</p>
                                      <input asp-for="Document.PersonalSection.Items[i].ImageSrc" id="personalImageSrcInput-@i" />
                                    </div>
                                    <div class="field">
                                      <label asp-for="Document.PersonalSection.Items[i].ImageAlt"></label>
                                      <p class="field-help">画像が見えない場合にも内容が伝わる説明文です。例: 管理画面のスクリーンショット</p>
                                      <input asp-for="Document.PersonalSection.Items[i].ImageAlt" id="personalImageAltInput-@i" data-character-count data-character-limit="80" />
                                      <p class="field-help character-counter" aria-live="polite">0 / 80 文字目安</p>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="field field-full">
                            <label for="personal-stack-@i">技術スタック</label>
                            <textarea id="personal-stack-@i" name="Document.PersonalSection.Items[@i].Stack" class="selection-storage" hidden>@doc.PersonalSection.Items[i].Stack</textarea>
                            <div class="stack-selection" data-selection-group="personal-stack-@i" data-selection-target="personal-stack-@i">
                              <div class="stack-selection-summary">
                                <span>選択中 <strong data-selection-summary-for="personal-stack-@i">@selectedPersonalStack.Count</strong> 件</span>
                                <small>取り組みの中心技術をジャンルから選択します。</small>
                              </div>
                              <div class="stack-group-list">
                                @for (var groupIndex = 0; groupIndex < personalStackGroups.Count; groupIndex++)
                                {
                                    var group = personalStackGroups[groupIndex];
                                    <section class="stack-option-group" aria-label="@group.Label">
                                      <div class="stack-option-group-label">
                                        <span>@group.Label</span>
                                      </div>
                                      <div class="selection-list">
                                        @for (var optionIndex = 0; optionIndex < group.Options.Count; optionIndex++)
                                        {
                                            var option = group.Options[optionIndex];
                                            var optionId = $"personal-stack-{i}-{groupIndex}-{optionIndex}";
                                            var isSelected = selectedPersonalStack.Contains(option);
                                            <label class="selection-chip @(isSelected ? "is-selected" : string.Empty)" for="@optionId">
                                              <input id="@optionId" type="checkbox" value="@option" checked="@isSelected" />
                                              <span>@option</span>
                                            </label>
                                        }
                                      </div>
                                    </section>
                                }
                              </div>
                            </div>
                            <p class="field-help">保存時は選択順ではなく、ジャンルごとの表示順で保存されます。</p>
                          </div>
                        </div>
                      </section>
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="contact-panel">
        <div class="section-header">
          <p class="section-eyebrow">連絡先</p>
          <h2>連絡先</h2>
          <p class="section-description">
            連絡先と外部リンクを編集します。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">@doc.Contact.Links.Count 件</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.Contact.Heading"></label>
              <input asp-for="Document.Contact.Heading" />
            </div>
            <div class="field">
              <label asp-for="Document.Contact.Email"></label>
              <input asp-for="Document.Contact.Email" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.Contact.Note"></label>
              <textarea asp-for="Document.Contact.Note"></textarea>
            </div>
          </div>

          <div class="collection">
            <div class="collection-header">
              <div>
                <p class="section-eyebrow">リンク</p>
                <h3>外部リンク</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:contact-link">リンクを追加</button>
              </div>
            </div>
            <div class="item-list">
              @if (doc.Contact.Links.Count == 0)
              {
                  <p class="empty-message">連絡先リンクはまだありません。必要な数だけ追加してください。</p>
              }
              @for (var i = 0; i < doc.Contact.Links.Count; i++)
              {
                  <article class="item-card">
                    <div class="item-card-header">
                      <h4>リンク @(i + 1)</h4>
                      <div class="inline-actions">
                        <button class="button button-danger" type="submit" name="editorAction" value="remove:contact-link:@i">削除</button>
                      </div>
                    </div>
                    <div class="field-grid">
                      <div class="field">
                        <label asp-for="Document.Contact.Links[i].Label"></label>
                        <input asp-for="Document.Contact.Links[i].Label" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.Contact.Links[i].Href"></label>
                        <input asp-for="Document.Contact.Links[i].Href" />
                        <p class="field-help">/ で始まるサイト内パス、または http/https / mailto / tel の URL を指定できます。</p>
                      </div>
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>
      </main>
    </div>
  </form>
</div>
