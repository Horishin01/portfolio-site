                          data-personal-action="listing"
                          asp-controller="Home"
                          asp-action="Index"
                          asp-fragment="personal"
                          target="_blank"
                          rel="noreferrer"
                        >
                          公開一覧を確認
                        </a>
                        <a
                          class="button button-secondary"
                          data-personal-action="detail"
                          asp-controller="Home"
                          asp-action="Personal"
                          asp-route-index="@i"
                          asp-route-slug="@(!string.IsNullOrWhiteSpace(personalSlug) ? personalSlug : null)"
                          target="_blank"
                          rel="noreferrer"
                        >
                          個別ページを確認
                        </a>
