              <span>全</span>
              全て表示
            </button>
            <button class="personal-tab is-active" id="personal-tab-index" type="button" role="tab" aria-selected="true" data-personal-tab="index">
              <span>1</span>
              トップ共通
            </button>
            <button class="personal-tab" id="personal-tab-listing" type="button" role="tab" aria-selected="false" data-personal-tab="listing">
              <span>2</span>
              一覧カード
            </button>
            <button class="personal-tab" id="personal-tab-detail" type="button" role="tab" aria-selected="false" data-personal-tab="detail">
              <span>3</span>
              個別ページ
            </button>
            <button class="personal-tab" id="personal-tab-shared" type="button" role="tab" aria-selected="false" data-personal-tab="shared">
              <span>4</span>
              共通素材
            </button>
          </div>

          <section class="personal-channel-card is-index" aria-label="トップページ PERSONAL 共通設定" data-personal-tab-panel="index">
            <div class="personal-channel-header">
              <span class="editor-scope-label">トップページ</span>
              <h3>PERSONAL セクション共通設定</h3>
            </div>
            <div class="field-grid">
              <div class="field">
                <label asp-for="Document.PersonalSection.Heading"></label>
                <p class="field-help">トップページの PERSONAL セクション見出しです。例: 個人活動</p>
                <input asp-for="Document.PersonalSection.Heading" />
              </div>
              <div class="field field-full">
                <label asp-for="Document.PersonalSection.Intro"></label>
                <p class="field-help">トップページの一覧全体に出る導入文です。各カードの説明ではありません。</p>
                <textarea asp-for="Document.PersonalSection.Intro" data-character-count data-character-limit="180"></textarea>
                <p class="field-help character-counter" aria-live="polite">0 / 180 文字目安</p>
              </div>
            </div>
