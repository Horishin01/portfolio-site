                <p class="section-eyebrow" data-personal-collection-eyebrow>項目</p>
                <h3 data-personal-collection-title>個人活動ごとの編集</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:personal-item">個人活動を追加</button>
              </div>
