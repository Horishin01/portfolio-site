@model PortfolioEditorViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "ポートフォリオ編集";

    static HashSet<string> SplitSelectionValues(string? value)
    {
        return (value ?? string.Empty)
            .Split('\n', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Select(item => item.TrimStart('-', '*', '+', ' '))
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    static List<PortfolioEditorOptionGroup> BuildSelectionOptionGroups(
        IReadOnlyList<PortfolioEditorOptionGroup> baseGroups,
        string? currentValue,
        IReadOnlySet<string> knownOptions
    )
    {
        var groups = baseGroups
            .Select(group => new PortfolioEditorOptionGroup(group.Label, group.Options))
            .ToList();

        var additionalOptions = SplitSelectionValues(currentValue)
            .Where(option => !knownOptions.Contains(option))
            .OrderBy(option => option, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (additionalOptions.Count > 0)
        {
            groups.Add(new PortfolioEditorOptionGroup("既存値", additionalOptions));
        }

        return groups;
    }

    static List<string> GetAdditionalTagOptions(IEnumerable<string> currentEntries)
    {
        return currentEntries
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Select(item => item.Trim())
            .Where(item => !PortfolioEditorOptionCatalog.KnownProfileTags.Contains(item))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(item => item, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    static string GetPersonalItemImageFieldName(int index)
    {
        return $"PersonalItemImageFile_{index}";
    }

    static int? ParsePeriodNumber(string? value)
    {
        return int.TryParse(value, out var parsed) ? parsed : null;
    }

    static (int Year, int Month)? GetCareerTimelineKey(CareerItem item)
    {
        if (string.Equals(item.PeriodEndYear, "現在", StringComparison.Ordinal))
        {
            return (9999, 12);
        }

        var endYear = ParsePeriodNumber(item.PeriodEndYear);
        if (endYear is int resolvedEndYear)
        {
            return (resolvedEndYear, ParsePeriodNumber(item.PeriodEndMonth) ?? 12);
        }

        var startYear = ParsePeriodNumber(item.PeriodStartYear);
        if (startYear is int resolvedStartYear)
        {
            return (resolvedStartYear, ParsePeriodNumber(item.PeriodStartMonth) ?? 1);
        }

        return null;
    }

    var tone = ViewData["StatusTone"] as string ?? TempData["StatusTone"] as string;
    var tempMessage = ViewData["StatusMessage"] as string ?? TempData["StatusMessage"] as string;
    var hasErrors = !ViewData.ModelState.IsValid;
    var validationMessage = ValidationMessageLocalizer.GetFirstError(ViewData.ModelState);
    var statusMessage = validationMessage ?? tempMessage ?? "フォームを編集して保存してください。";
    var statusClass = hasErrors
        ? "is-error"
        : tone is "success" ? "is-success"
        : tone is "warning" ? "is-warning"
        : string.Empty;
    var restoreScrollY = ViewData["RestoreScrollY"] as int?;
    var adminShellClass = restoreScrollY is int ? "admin-shell is-visible restore-scroll-pending" : "admin-shell is-visible";
    var doc = Model.Document;
    var faviconPreviewSrc = PublicUrlSanitizer.SanitizeFaviconUrl(doc.FaviconSrc);
    var heroImagePreviewSrc = PublicUrlSanitizer.SanitizeImageUrl(doc.Profile.HeroImageSrc);
    var hasFavicon = !string.IsNullOrWhiteSpace(faviconPreviewSrc);
    var hasHeroImage = !string.IsNullOrWhiteSpace(heroImagePreviewSrc);
    var heroMark = string.IsNullOrWhiteSpace(doc.Profile.ShortName) ? "IMG" : doc.Profile.ShortName;
    var totalCards = doc.Profile.Highlights.Count
        + doc.CareerSection.Items.Count
        + doc.SkillsSection.Categories.Count
        + doc.WorksSection.Items.Count
        + doc.PersonalSection.Items.Count
        + doc.Contact.Links.Count;
    var totalSkillItems = doc.SkillsSection.Categories.Sum(category => category.Items.Count);
    var sectionLinks = new (string Id, string Eyebrow, string Label, string Icon)[]
    {
        ("site-panel", "設定", "基本設定", "fa-solid fa-sliders"),
        ("hero-panel", "ヒーロー", "プロフィール", "fa-solid fa-id-card"),
        ("profile-panel", "紹介", "自己紹介", "fa-solid fa-align-left"),
        ("career-panel", "経歴", "在籍歴", "fa-solid fa-briefcase"),
        ("skills-panel", "スキル", "スキル", "fa-solid fa-layer-group"),
        ("works-panel", "実績", "実績", "fa-solid fa-diagram-project"),
        ("personal-panel", "個人", "個人活動", "fa-solid fa-flask"),
        ("contact-panel", "連絡", "連絡先", "fa-solid fa-paper-plane")
    };
    var additionalProfileTagOptions = GetAdditionalTagOptions(Model.ProfileTagEntries);
    var careerTimelineRanks = doc.CareerSection.Items
        .Select((item, index) => new
        {
            Index = index,
            TimelineKey = GetCareerTimelineKey(item)
        })
        .Where(item => item.TimelineKey.HasValue)
        .OrderByDescending(item => item.TimelineKey!.Value.Year)
        .ThenByDescending(item => item.TimelineKey!.Value.Month)
        .Select((item, rank) => new
        {
            item.Index,
            Label = rank == 0 ? "時系列: 最新" : $"時系列: 過去 {rank}件前"
        })
        .ToDictionary(item => item.Index, item => item.Label);
}
<div class="@adminShellClass" id="adminShell" data-restore-scroll-y="@restoreScrollY">
  <header class="admin-header editor-command-header">
    <div class="editor-command-copy">
      <p class="admin-eyebrow">Content Studio</p>
      <h1>ポートフォリオ編集</h1>
      <p class="admin-note">
        公開ページの見え方を意識しながら、基本情報、プロフィール、実績、個人活動、連絡先をまとめて管理します。
      </p>
    </div>

    <div class="admin-header-actions editor-command-actions" aria-label="主要操作">
      <button class="button button-save" form="editorForm" type="submit"><i class="fa-solid fa-floppy-disk" aria-hidden="true"></i><span>保存</span></button>
      <a class="button button-secondary" asp-controller="Home" asp-action="Index" target="_blank" rel="noreferrer"><i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i><span>サイトを見る</span></a>
      <a class="button button-ghost" asp-action="Index"><i class="fa-solid fa-table-columns" aria-hidden="true"></i><span>ポータル</span></a>
      <a class="button button-ghost" asp-action="Adsense"><i class="fa-brands fa-google" aria-hidden="true"></i><span>AdSense</span></a>
      <a class="button button-ghost" asp-action="Account"><i class="fa-solid fa-user-gear" aria-hidden="true"></i><span>アカウント</span></a>
      <form asp-action="Logout" method="post" class="inline-form" data-admin-session-event-submit="logout">
        <button class="button button-ghost" type="submit"><i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i><span>ログアウト</span></button>
      </form>
    </div>
  </header>

  <section class="admin-toolbar editor-status-bar">
    <div class="toolbar-group">
      <span class="editor-status-pill"><i class="fa-regular fa-clock" aria-hidden="true"></i> @Model.UpdatedAtJst.ToString("yyyy-MM-dd HH:mm:ss 'JST'")</span>
      <span class="editor-status-pill"><i class="fa-solid fa-language" aria-hidden="true"></i> @doc.Locale</span>
      <span class="editor-status-pill"><i class="fa-solid fa-image" aria-hidden="true"></i> @(hasHeroImage ? "ヒーロー画像あり" : "ヒーロー画像なし")</span>
    </div>
    <div class="toolbar-group">
      <form asp-action="Reset" method="post" class="inline-form" data-confirm="初期データへ戻します。現在の保存内容は上書きされます。">
        <button class="button button-danger" type="submit"><i class="fa-solid fa-rotate-left" aria-hidden="true"></i><span>初期値に戻す</span></button>
      </form>
    </div>
  </section>

  <p class="status-message @statusClass">@statusMessage</p>

  <form id="editorForm" asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" id="editorScrollY" name="editorScrollY" value="" />
    <section class="editor-overview editor-cockpit">
      <div class="editor-overview-main">
        <p class="admin-eyebrow">Publishing Snapshot</p>
        <h2>@doc.SiteTitle</h2>
        <p class="admin-note">
          言語設定は <strong>@doc.Locale</strong>、ファビコンは <strong>@(hasFavicon ? "設定済み" : "未設定")</strong>、ヒーロー画像は <strong>@(hasHeroImage ? "設定済み" : "未設定")</strong> です。
          保存した内容は EF Core を通してデータベースに反映され、公開ページに表示されます。
        </p>

        <div class="editor-chip-row">
          <span class="editor-chip">セクション数 @sectionLinks.Length</span>
          <span class="editor-chip">編集項目数 @totalCards</span>
          <span class="editor-chip">スキル数 @totalSkillItems</span>
          <span class="editor-chip">最終更新 @Model.UpdatedAtJst.ToString("MM-dd HH:mm") JST</span>
        </div>
      </div>

      <div class="editor-overview-stats">
        <article class="editor-stat-card">
          <span class="editor-stat-label">Sections</span>
          <strong>@sectionLinks.Length</strong>
          <p>編集対象セクション</p>
        </article>
        <article class="editor-stat-card">
          <span class="editor-stat-label">Hero</span>
          <strong>@(hasHeroImage ? "設定済み" : "未設定")</strong>
          <p>@(hasHeroImage ? "画像が設定されています。" : "画像をアップロードするか、画像URLを入力してください。")</p>
        </article>
        <article class="editor-stat-card">
          <span class="editor-stat-label">Items</span>
          <strong>@totalCards</strong>
          <p>編集対象のカードとリンクの合計</p>
        </article>
      </div>
    </section>

    <div class="editor-workspace">
      <nav class="section-nav" aria-label="編集セクションナビゲーション">
        <div class="section-nav-heading">
          <span>Navigator</span>
          <strong>編集セクション</strong>
        </div>
        @foreach (var sectionLink in sectionLinks)
        {
            <a class="section-nav-link" href="#@sectionLink.Id">
              <i class="@sectionLink.Icon" aria-hidden="true"></i>
              <span>@sectionLink.Eyebrow</span>
              <strong>@sectionLink.Label</strong>
            </a>
        }
      </nav>

      <main class="admin-layout">
      <section class="admin-section" id="site-panel">
        <div class="section-header">
          <p class="section-eyebrow">設定</p>
          <h2>基本設定</h2>
          <p class="section-description">
            サイト全体のメタ情報とブラウザタブ用アイコンです。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">基本情報</span>
            <span class="section-meta-tag">@(hasFavicon ? "ファビコン設定済み" : "ファビコン未設定")</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.Locale"></label>
              <input asp-for="Document.Locale" />
            </div>
            <div class="field">
              <label asp-for="Document.FooterRole"></label>
              <input asp-for="Document.FooterRole" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.SiteTitle"></label>
              <input asp-for="Document.SiteTitle" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.MetaDescription"></label>
              <textarea asp-for="Document.MetaDescription"></textarea>
            </div>
          </div>

          <div class="field image-field">
            <label>ファビコンプレビュー</label>
            <div class="image-field-shell">
              <div class="favicon-preview-row">
                <div class="image-preview-card icon-preview-card @(hasFavicon ? "has-image" : string.Empty)" id="faviconPreviewCard">
                  <img
                    class="image-preview-media"
                    id="faviconPreviewMedia"
                    src="@(hasFavicon ? faviconPreviewSrc : string.Empty)"
                    alt="ファビコンプレビュー"
                    hidden="@(!hasFavicon)"
                  />
                  <div class="image-preview-placeholder">
                    <span class="image-preview-mark">ICO</span>
                    <div class="image-preview-copy">
                      <strong>ブラウザタブのアイコン</strong>
                      <p>アップロードまたは URL を設定すると、ここにプレビューされます。</p>
                    </div>
                  </div>
                </div>

                <div class="field favicon-upload-field">
                  <label asp-for="FaviconFile">ファビコンアップロード</label>
                  <input asp-for="FaviconFile" id="faviconFile" type="file" accept=".ico,.png,.webp,.jpg,.jpeg,.gif" />
                  <p class="field-help">ICO / PNG / WEBP / JPG / GIF に対応しています。1MBまでアップロードでき、ファビコンURLより優先して保存されます。</p>
                  <p class="field-help">未設定の場合は既定のアイコンを使用します。</p>
                  <p class="field-help">URLは / で始まるサイト内パス、または https の画像URLのみ指定できます。SVG は受け付けません。</p>

                  <div class="hero-upload-meta">
                    <div class="field">
                      <label asp-for="Document.FaviconSrc"></label>
                      <input asp-for="Document.FaviconSrc" id="faviconSrcInput" />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="hero-panel">
        <div class="section-header">
          <p class="section-eyebrow">ヒーロー</p>
          <h2>プロフィール</h2>
          <p class="section-description">
            ファーストビューとプロフィールの基本情報です。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">@(hasHeroImage ? "画像設定済み" : "画像未設定")</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field image-field">
            <label>ヒーロー画像プレビュー</label>
            <div class="image-field-shell">
              <div class="hero-preview-row">
                <div class="image-preview-card @(hasHeroImage ? "has-image" : string.Empty)" id="heroImagePreviewCard">
                  <img
                    class="image-preview-media"
                    id="heroImagePreviewMedia"
                    src="@(hasHeroImage ? heroImagePreviewSrc : string.Empty)"
                    alt="@(string.IsNullOrWhiteSpace(doc.Profile.HeroImageAlt) ? "ヒーロー画像プレビュー" : doc.Profile.HeroImageAlt)"
                    hidden="@(!hasHeroImage)"
                  />
                  <div class="image-preview-placeholder">
                    <span class="image-preview-mark">@heroMark</span>
                    <div class="image-preview-copy">
                      <strong>ヒーロー画像</strong>
                      <p>画像をアップロードするか、画像URLを入力すると、ここに表示されます。</p>
                    </div>
                  </div>
                </div>
                <div class="field hero-upload-field">
                  <label asp-for="HeroImageFile">ヒーロー画像アップロード</label>
                  <input asp-for="HeroImageFile" id="heroImageFile" type="file" accept=".jpg,.jpeg,.png,.webp,.gif" />
                  <p class="field-help">JPG / PNG / WEBP / GIF に対応しています。5MBまでアップロードでき、画像URLより優先して保存されます。</p>
                  <p class="field-help">画像をアップロードしない場合は、下の画像URLを使用します。画像の説明文もここで設定できます。</p>
                  <p class="field-help">画像URLは / で始まるサイト内パス、または https の URL のみ指定できます。</p>

                  <div class="hero-upload-meta">
                    <div class="field">
                      <label asp-for="Document.Profile.HeroImageSrc"></label>
                      <input asp-for="Document.Profile.HeroImageSrc" id="heroImageSrcInput" />
                    </div>
                    <div class="field">
                      <label asp-for="Document.Profile.HeroImageAlt"></label>
                      <input asp-for="Document.Profile.HeroImageAlt" id="heroImageAltInput" />
                    </div>
                  </div>
                </div>
              </div>
              <div class="image-field-controls">
                <div class="field-grid">
                  <div class="field">
                    <label asp-for="Document.Profile.Name"></label>
                    <input asp-for="Document.Profile.Name" />
                  </div>
                  <div class="field">
                    <label asp-for="Document.Profile.ShortName"></label>
                    <input asp-for="Document.Profile.ShortName" />
                  </div>
                  <div class="field">
                    <label asp-for="Document.Profile.Role"></label>
                    <input asp-for="Document.Profile.Role" />
                  </div>
                  <div class="field">
                    <label asp-for="Document.Profile.HeroEyebrow"></label>
                    <input asp-for="Document.Profile.HeroEyebrow" />
                  </div>
                  <div class="field field-full">
                    <label asp-for="Document.Profile.HeroTitle"></label>
                    <input asp-for="Document.Profile.HeroTitle" />
                  </div>
                  <div class="field field-full">
                    <label asp-for="Document.Profile.Summary"></label>
                    <textarea asp-for="Document.Profile.Summary"></textarea>
                  </div>
                  <div class="field field-full">
                    <div class="field-inline-header">
                      <label>タグ</label>
                      <button class="button button-secondary" type="submit" name="editorAction" value="add:profile-tag">タグを追加</button>
                    </div>
                    <div class="dynamic-entry-list">
                      @if (Model.ProfileTagEntries.Count == 0)
                      {
                          <p class="empty-message">タグはまだありません。追加してから候補を選択してください。</p>
                      }
                      @for (var i = 0; i < Model.ProfileTagEntries.Count; i++)
                      {
                          <div class="dynamic-entry-row">
                            <div class="field field-compact">
                              <label for="profile-tag-entry-@i">タグ @(i + 1)</label>
                              <select id="profile-tag-entry-@i" name="ProfileTagEntries[@i]">
                                <option value="">項目を選択してください</option>
                                @foreach (var group in PortfolioEditorOptionCatalog.ProfileTagGroups)
                                {
                                    <optgroup label="@group.Label">
                                      @foreach (var option in group.Options)
                                      {
                                          <option value="@option" selected="@(string.Equals(Model.ProfileTagEntries[i], option, StringComparison.OrdinalIgnoreCase))">@option</option>
                                      }
                                    </optgroup>
                                }
                                @if (additionalProfileTagOptions.Count > 0)
                                {
                                    <optgroup label="既存値">
                                      @foreach (var option in additionalProfileTagOptions)
                                      {
                                          <option value="@option" selected="@(string.Equals(Model.ProfileTagEntries[i], option, StringComparison.OrdinalIgnoreCase))">@option</option>
                                      }
                                    </optgroup>
                                }
                              </select>
                            </div>
                            <button class="button button-danger" type="submit" name="editorAction" value="remove:profile-tag:@i">削除</button>
                          </div>
                      }
                    </div>
                    <p class="field-help">ジャンルごとに分けた候補から1件ずつ選んで追加します。</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="collection">
            <div class="collection-header">
              <div>
                <p class="section-eyebrow">指標</p>
                <h3>プロフィール指標</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:profile-highlight">指標を追加</button>
              </div>
            </div>
            <div class="item-list">
              @if (doc.Profile.Highlights.Count == 0)
              {
                  <p class="empty-message">プロフィール指標はまだありません。必要な数だけ追加してください。</p>
              }
              @for (var i = 0; i < doc.Profile.Highlights.Count; i++)
              {
                  <article class="item-card">
                    <div class="item-card-header">
                      <h4>指標 @(i + 1)</h4>
                      <div class="inline-actions">
                        <button class="button button-danger" type="submit" name="editorAction" value="remove:profile-highlight:@i">削除</button>
                      </div>
                    </div>
                    <div class="field-grid">
                      <div class="field">
                        <label asp-for="Document.Profile.Highlights[i].Label"></label>
                        <input asp-for="Document.Profile.Highlights[i].Label" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.Profile.Highlights[i].Value"></label>
                        <input asp-for="Document.Profile.Highlights[i].Value" />
                      </div>
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="profile-panel">
        <div class="section-header">
          <p class="section-eyebrow">紹介</p>
          <h2>自己紹介セクション</h2>
          <p class="section-description">
            自己紹介エリアの本文と補足情報です。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">紹介本文</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.ProfileSection.Heading"></label>
              <input asp-for="Document.ProfileSection.Heading" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.ProfileSection.Intro"></label>
              <textarea asp-for="Document.ProfileSection.Intro"></textarea>
            </div>
            <div class="field field-full">
              <label asp-for="Document.ProfileSection.Lead"></label>
              <textarea asp-for="Document.ProfileSection.Lead"></textarea>
            </div>
            <div class="field field-full">
              <label asp-for="Document.ProfileSection.Body"></label>
              <textarea asp-for="Document.ProfileSection.Body"></textarea>
            </div>
            <div class="field">
              <label asp-for="Document.ProfileSection.FocusHeading"></label>
              <input asp-for="Document.ProfileSection.FocusHeading" />
            </div>
            <div class="field">
              <label asp-for="Document.ProfileSection.CertificationsHeading"></label>
              <input asp-for="Document.ProfileSection.CertificationsHeading" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.ProfileSection.FocusItems"></label>
              <textarea asp-for="Document.ProfileSection.FocusItems"></textarea>
            </div>
            <div class="field field-full">
              <div class="field-inline-header">
                <label>資格・認定</label>
                <button class="button button-secondary" type="submit" name="editorAction" value="add:certification">資格を追加</button>
              </div>
              <div class="dynamic-entry-list">
                @if (Model.CertificationEntries.Count == 0)
                {
                    <p class="empty-message">資格はまだありません。必要な数だけ追加してください。</p>
                }
                @for (var i = 0; i < Model.CertificationEntries.Count; i++)
                {
                    <div class="dynamic-entry-row">
                      <div class="field field-compact">
                        <label for="certification-entry-@i">資格 @(i + 1)</label>
                        <input id="certification-entry-@i" name="CertificationEntries[@i]" value="@Model.CertificationEntries[i]" />
                      </div>
                      <button class="button button-danger" type="submit" name="editorAction" value="remove:certification:@i">削除</button>
                    </div>
                }
              </div>
              <p class="field-help">資格は1件ずつ追加して入力します。</p>
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="career-panel">
        <div class="section-header">
          <p class="section-eyebrow">経歴</p>
          <h2>在籍歴</h2>
          <p class="section-description">
            在籍歴セクションの見出しと各項目を編集します。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">@doc.CareerSection.Items.Count 件</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.CareerSection.Heading"></label>
              <input asp-for="Document.CareerSection.Heading" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.CareerSection.Intro"></label>
              <textarea asp-for="Document.CareerSection.Intro"></textarea>
            </div>
          </div>

          <div class="collection">
            <div class="collection-header">
              <div>
                <p class="section-eyebrow">項目</p>
                <h3>在籍歴項目</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:career-item">在籍歴を追加</button>
              </div>
            </div>
            <div class="item-list">
              @if (doc.CareerSection.Items.Count == 0)
              {
                  <p class="empty-message">在籍歴項目はまだありません。必要な数だけ追加してください。</p>
              }
              @for (var i = 0; i < doc.CareerSection.Items.Count; i++)
              {
                  var timelineLabel = careerTimelineRanks.TryGetValue(i, out var resolvedTimelineLabel)
                      ? resolvedTimelineLabel
                      : "時系列: 期間未設定";
                  <article class="item-card">
                    <div class="item-card-header">
                      <div class="item-card-title">
                        <h4>在籍歴 @(i + 1)</h4>
                        <div class="item-card-tag-row">
                          <span class="item-card-tag is-timeline">@timelineLabel</span>
                          <span class="item-card-tag is-order">公開表示順 @(i + 1)</span>
                        </div>
                      </div>
                      <div class="inline-actions">
                        <button class="button button-danger" type="submit" name="editorAction" value="remove:career-item:@i">削除</button>
                      </div>
                    </div>
                    <div class="field-grid">
                      <div class="field field-full career-period-field">
                        <div class="field-inline-header">
                          <label>期間</label>
                          <span class="editor-chip">@doc.CareerSection.Items[i].Period</span>
                        </div>
                        <div class="career-period-grid">
                          <div class="career-period-group">
                            <span class="career-period-label">開始</span>
                            <div class="career-period-controls">
                              <select asp-for="Document.CareerSection.Items[i].PeriodStartYear" aria-label="開始年">
                                <option value="">年</option>
                                @foreach (var year in PortfolioEditorOptionCatalog.CareerYearOptions)
                                {
                                    <option value="@year">@year 年</option>
                                }
                                @if (!string.IsNullOrWhiteSpace(doc.CareerSection.Items[i].PeriodStartYear)
                                    && !PortfolioEditorOptionCatalog.CareerYearOptions.Contains(doc.CareerSection.Items[i].PeriodStartYear))
                                {
                                    <option value="@doc.CareerSection.Items[i].PeriodStartYear" selected>既存値: @doc.CareerSection.Items[i].PeriodStartYear 年</option>
                                }
                              </select>
                              <select asp-for="Document.CareerSection.Items[i].PeriodStartMonth" aria-label="開始月">
                                <option value="">月</option>
                                @foreach (var month in PortfolioEditorOptionCatalog.MonthOptions)
                                {
                                    <option value="@month">@month 月</option>
                                }
                              </select>
                            </div>
                          </div>
                          <div class="career-period-group">
                            <span class="career-period-label">終了</span>
                            <div class="career-period-controls">
                              <select asp-for="Document.CareerSection.Items[i].PeriodEndYear" aria-label="終了年" data-current-year-select data-current-month-target="career-end-month-@i">
                                <option value="">年</option>
                                <option value="現在">現在</option>
                                @foreach (var year in PortfolioEditorOptionCatalog.CareerYearOptions)
                                {
                                    <option value="@year">@year 年</option>
                                }
                                @if (!string.IsNullOrWhiteSpace(doc.CareerSection.Items[i].PeriodEndYear)
                                    && doc.CareerSection.Items[i].PeriodEndYear != "現在"
                                    && !PortfolioEditorOptionCatalog.CareerYearOptions.Contains(doc.CareerSection.Items[i].PeriodEndYear))
                                {
                                    <option value="@doc.CareerSection.Items[i].PeriodEndYear" selected>既存値: @doc.CareerSection.Items[i].PeriodEndYear 年</option>
                                }
                              </select>
                              <select asp-for="Document.CareerSection.Items[i].PeriodEndMonth" id="career-end-month-@i" aria-label="終了月">
                                <option value="">月</option>
                                @foreach (var month in PortfolioEditorOptionCatalog.MonthOptions)
                                {
                                    <option value="@month">@month 月</option>
                                }
                              </select>
                            </div>
                          </div>
                        </div>
                        <p class="field-help">年は1900年からサーバ日時の翌年まで自動で表示します。「現在」を選ぶと、公開ページではサーバ日時の「現在yyyy年 M月」として表示します。</p>
                      </div>
                      <div class="field">
                        <label asp-for="Document.CareerSection.Items[i].Category"></label>
                        <input asp-for="Document.CareerSection.Items[i].Category" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.CareerSection.Items[i].Organization"></label>
                        <input asp-for="Document.CareerSection.Items[i].Organization" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.CareerSection.Items[i].Title"></label>
                        <input asp-for="Document.CareerSection.Items[i].Title" />
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.CareerSection.Items[i].Description"></label>
                        <textarea asp-for="Document.CareerSection.Items[i].Description"></textarea>
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.CareerSection.Items[i].Highlights"></label>
                        <textarea asp-for="Document.CareerSection.Items[i].Highlights"></textarea>
                      </div>
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="skills-panel">
        <div class="section-header">
          <p class="section-eyebrow">スキル</p>
          <h2>スキル</h2>
          <p class="section-description">
            カテゴリごとにスキルを管理します。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">カテゴリ @doc.SkillsSection.Categories.Count</span>
            <span class="section-meta-tag">項目 @totalSkillItems</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.SkillsSection.Heading"></label>
              <input asp-for="Document.SkillsSection.Heading" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.SkillsSection.Intro"></label>
              <textarea asp-for="Document.SkillsSection.Intro"></textarea>
            </div>
          </div>

          <div class="collection">
            <div class="collection-header">
              <div>
                <p class="section-eyebrow">カテゴリ</p>
                <h3>スキルカテゴリ</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:skill-category">カテゴリを追加</button>
              </div>
            </div>
            <div class="item-list">
              @if (doc.SkillsSection.Categories.Count == 0)
              {
                  <p class="empty-message">スキルカテゴリはまだありません。必要な数だけ追加してください。</p>
              }
              @for (var categoryIndex = 0; categoryIndex < doc.SkillsSection.Categories.Count; categoryIndex++)
              {
                  <article class="item-card">
                    <div class="item-card-header">
                      <h4>カテゴリ @(categoryIndex + 1)</h4>
                      <div class="inline-actions">
                        <button class="button button-secondary" type="submit" name="editorAction" value="add:skill-item:@categoryIndex">スキル項目を追加</button>
                        <button class="button button-danger" type="submit" name="editorAction" value="remove:skill-category:@categoryIndex">カテゴリを削除</button>
                      </div>
                    </div>
                    <div class="field-grid">
                      <div class="field">
                        <label asp-for="Document.SkillsSection.Categories[categoryIndex].Title"></label>
                        <input asp-for="Document.SkillsSection.Categories[categoryIndex].Title" />
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.SkillsSection.Categories[categoryIndex].Summary"></label>
                        <textarea asp-for="Document.SkillsSection.Categories[categoryIndex].Summary"></textarea>
                      </div>
                    </div>

                    <div class="nested-list">
                      @if (doc.SkillsSection.Categories[categoryIndex].Items.Count == 0)
                      {
                          <p class="empty-message">このカテゴリにはスキル項目がありません。追加して入力してください。</p>
                      }
                      @for (var itemIndex = 0; itemIndex < doc.SkillsSection.Categories[categoryIndex].Items.Count; itemIndex++)
                      {
                          <div class="nested-item">
                            <div class="nested-item-header">
                              <h5>スキル項目 @(itemIndex + 1)</h5>
                              <div class="inline-actions">
                                <button class="button button-danger" type="submit" name="editorAction" value="remove:skill-item:@categoryIndex:@itemIndex">削除</button>
                              </div>
                            </div>
                            <div class="field-grid">
                              <div class="field">
                                <label asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Name"></label>
                                <input asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Name" />
                              </div>
                              <div class="field">
                                <label asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Experience"></label>
                                <input asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Experience" />
                              </div>
                              <div class="field field-full">
                                <label asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Note"></label>
                                <textarea asp-for="Document.SkillsSection.Categories[categoryIndex].Items[itemIndex].Note"></textarea>
                              </div>
                            </div>
                          </div>
                      }
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="works-panel">
        <div class="section-header">
          <p class="section-eyebrow">実績</p>
          <h2>実績</h2>
          <p class="section-description">
            実績カードを表示順に編集できます。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">@doc.WorksSection.Items.Count 件</span>
          </div>
        </div>
        <div class="admin-section-content">
          <div class="field-grid">
            <div class="field">
              <label asp-for="Document.WorksSection.Heading"></label>
              <input asp-for="Document.WorksSection.Heading" />
            </div>
            <div class="field field-full">
              <label asp-for="Document.WorksSection.Intro"></label>
              <textarea asp-for="Document.WorksSection.Intro"></textarea>
            </div>
          </div>

          <div class="collection">
            <div class="collection-header">
              <div>
                <p class="section-eyebrow">項目</p>
                <h3>実績カード</h3>
              </div>
              <div class="inline-actions">
                <button class="button button-secondary" type="submit" name="editorAction" value="add:work-item">実績を追加</button>
              </div>
            </div>
            <div class="item-list">
              @if (doc.WorksSection.Items.Count == 0)
              {
                  <p class="empty-message">実績項目はまだありません。必要な数だけ追加してください。</p>
              }
              @for (var i = 0; i < doc.WorksSection.Items.Count; i++)
              {
                  var selectedWorkStack = SplitSelectionValues(doc.WorksSection.Items[i].Stack);
                  var workStackGroups = BuildSelectionOptionGroups(
                      PortfolioEditorOptionCatalog.TechnologyOptionGroups,
                      doc.WorksSection.Items[i].Stack,
                      PortfolioEditorOptionCatalog.KnownTechnologyOptions
                  );
                  <article class="item-card">
                    <div class="item-card-header">
                      <h4>実績 @(i + 1)</h4>
                      <div class="inline-actions">
                        <button class="button button-danger" type="submit" name="editorAction" value="remove:work-item:@i">削除</button>
                      </div>
                    </div>
                    <div class="field-grid">
                      <div class="field">
                        <label asp-for="Document.WorksSection.Items[i].Title"></label>
                        <input asp-for="Document.WorksSection.Items[i].Title" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.WorksSection.Items[i].Year"></label>
                        <input asp-for="Document.WorksSection.Items[i].Year" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.WorksSection.Items[i].Type"></label>
                        <input asp-for="Document.WorksSection.Items[i].Type" />
                      </div>
                      <div class="field">
                        <label asp-for="Document.WorksSection.Items[i].Role"></label>
                        <input asp-for="Document.WorksSection.Items[i].Role" />
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.WorksSection.Items[i].Summary"></label>
                        <textarea asp-for="Document.WorksSection.Items[i].Summary"></textarea>
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.WorksSection.Items[i].Responsibilities"></label>
                        <textarea asp-for="Document.WorksSection.Items[i].Responsibilities"></textarea>
                      </div>
                      <div class="field field-full">
                        <label asp-for="Document.WorksSection.Items[i].Outcomes"></label>
                        <textarea asp-for="Document.WorksSection.Items[i].Outcomes"></textarea>
                      </div>
                      <div class="field field-full">
                        <label for="works-stack-@i">技術スタック</label>
                        <textarea id="works-stack-@i" name="Document.WorksSection.Items[@i].Stack" class="selection-storage" hidden>@doc.WorksSection.Items[i].Stack</textarea>
                        <div class="stack-selection" data-selection-group="works-stack-@i" data-selection-target="works-stack-@i">
                          <div class="stack-selection-summary">
                            <span>選択中 <strong data-selection-summary-for="works-stack-@i">@selectedWorkStack.Count</strong> 件</span>
                            <small>ジャンルごとに必要な技術だけ選択します。</small>
                          </div>
                          <div class="stack-group-list">
                            @for (var groupIndex = 0; groupIndex < workStackGroups.Count; groupIndex++)
                            {
                                var group = workStackGroups[groupIndex];
                                <section class="stack-option-group" aria-label="@group.Label">
                                  <div class="stack-option-group-label">
                                    <span>@group.Label</span>
                                  </div>
                                  <div class="selection-list">
                                    @for (var optionIndex = 0; optionIndex < group.Options.Count; optionIndex++)
                                    {
                                        var option = group.Options[optionIndex];
                                        var optionId = $"works-stack-{i}-{groupIndex}-{optionIndex}";
                                        var isSelected = selectedWorkStack.Contains(option);
                                        <label class="selection-chip @(isSelected ? "is-selected" : string.Empty)" for="@optionId">
                                          <input id="@optionId" type="checkbox" value="@option" checked="@isSelected" />
                                          <span>@option</span>
                                      </label>
                                    }
                                  </div>
                                </section>
                            }
                          </div>
                        </div>
                        <p class="field-help">保存時は選択順ではなく、ジャンルごとの表示順で保存されます。</p>
                      </div>
                    </div>
                  </article>
              }
            </div>
          </div>
        </div>
      </section>

      <section class="admin-section" id="personal-panel">
        <div class="section-header">
          <p class="section-eyebrow">個人</p>
          <h2>個人活動</h2>
          <p class="section-description">
            トップページの PERSONAL セクション、一覧カード、個別ページを編集します。
          </p>
          <div class="section-header-meta">
            <span class="section-meta-tag">@doc.PersonalSection.Items.Count 件</span>
          </div>
        </div>
        <div class="admin-section-content" data-personal-tabs data-active-personal-tab="index" data-personal-tab-storage-key="portfolio-admin-personal-tab">
          <div class="personal-tablist" role="tablist" aria-label="個人活動の編集画面">
